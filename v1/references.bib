@article{HedgesSadr2019,
	abstract = {Categorical compositional distributional semantics is a model of natural language; it combines the statistical vector space models of words with the compositional models of grammar. We formalise in this model the generalised quantifier theory of natural language, due to Barwise and Cooper. The underlying setting is a compact closed category with bialgebras. We start from a generative grammar formalisation and develop an abstract categorical compositional semantics for it, and then instantiate the abstract setting to sets and relations and to finite-dimensional vector spaces and linear maps. We prove the equivalence of the relational instantiation to the truth theoretic semantics of generalised quantifiers. The vector space instantiation formalises the statistical usages of words and enables us to, for the first time, reason about quantified phrases and sentences compositionally in distributional semantics.},
	archiveprefix = {arXiv},
	arxivid = {1602.01635},
	author = {Hedges, Jules and Sadrzadeh, Mehrnoosh},
	doi = {10.1017/S0960129518000324},
	eprint = {1602.01635},
	issn = {09601295},
	journal = {Mathematical Structures in Computer Science},
	keywords = {Compact Closed Categories,Compositional Distributional Semantics,Conservativity,Frobenius and Bialgebras,Generalised Quantifiers,Natural Language Semantics,Vector Space Semantics},
	title = {{A generalised quantifier theory of natural language in categorical compositional distributional semantics with bialgebras}},
	year = {2019},
	bdsk-url-1 = {https://doi.org/10.1017/S0960129518000324}}

@article{Sadretal2013Frob,
	abstract = {This article develops a compositional vector-based semantics of subject and object relative pronouns within a categorical framework. Frobenius algebras are used to formalize the operations required to model the semantics of relative pronouns, including passing information between the relative clause and the modified noun phrase, as well as copying, combining, and discarding parts of the relative clause. We develop two instantiations of the abstract semantics, one based on a truth-theoretic approach and one based on corpus statistics. {\textcopyright} 2013 The Author, 2013. Published by Oxford University Press. All rights reserved.},
	archiveprefix = {arXiv},
